# Discord gateway bot credentials
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-application-client-id
DISCORD_GUILD_ID=your-development-guild-id

# Runtime
VESPER_CONFIG=./vesper.config.json
VESPER_DB=./data/vesper.db
VESPER_ARTIFACT_ROOT=./data/artifacts

# Optional owner Discord user ID. Owners bypass normal role mapping for admin operations.
VESPER_OWNER_IDS=123456789012345678
